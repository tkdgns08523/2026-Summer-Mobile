<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/contact_header"
        android:textSize="25sp"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/contact_subtitle"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/number_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/number_display"
        android:textSize="32sp"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <!-- Keypad container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:padding="8dp">

        <!-- Row 1: 1 2 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_1"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_2"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_3"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Row 2: 4 5 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_4"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_5"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_6"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Row 3: 7 8 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_7"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_8"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_9"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Row 4: * 0 # -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_star"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_star"
                android:maxLines="1"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_0"
                android:maxLines="2"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn_hash"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_hash"
                android:maxLines="1"
                android:gravity="center"
                android:minHeight="56dp"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- Row 5: Video / Call / Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_video"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_video"
                android:textSize="18sp"
                android:gravity="center"
                android:minHeight="56dp" />

            <Button
                android:id="@+id/btn_call"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button_call"
                android:text="@string/btn_call"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:minHeight="56dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_button"
                android:text="@string/btn_delete"
                android:textSize="18sp"
                android:gravity="center"
                android:minHeight="56dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
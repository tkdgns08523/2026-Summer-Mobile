<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/water_bg"
    tools:context=".MainActivity">

    <!-- 인사말 -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 원형 진행률 + 펫 -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="28dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting">

        <!-- 배경 색상을 고르지 않았을 때만 보이는 기본 은은한 글로우 -->
        <View
            android:id="@+id/vPetGlow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_ring_glow" />

        <!-- 고른 배경 색으로 채워지는 원형 뷰 (코드에서 색을 입힌다) -->
        <View
            android:id="@+id/vPetBackgroundColor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_pet_color_fill"
            android:alpha="0.28"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressWater"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:max="100"
            android:progress="0"
            app:indicatorColor="@color/water_blue"
            app:indicatorSize="260dp"
            app:trackColor="@color/track_grey"
            app:trackCornerRadius="10dp"
            app:trackThickness="18dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="72sp"
                tools:text="🐣" />

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:textColor="@color/water_blue_dark"
                tools:text="0%"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:textColor="@color/text_secondary"
                tools:text="0 / 0 ml"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- 물 양 선택 버튼 -->
    <TextView
        android:id="@+id/tvDrinkSectionLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/main_drink_section_label"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/buttonRowCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDrinkSectionLabel">

        <LinearLayout
            android:id="@+id/buttonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn100"
                    style="@style/Widget.WaterBuddy.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:text="@string/drink_100"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn200"
                    style="@style/Widget.WaterBuddy.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:text="@string/drink_200"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn300"
                    style="@style/Widget.WaterBuddy.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:text="@string/drink_300"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn500"
                    style="@style/Widget.WaterBuddy.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:text="@string/drink_500"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCustomAmount"
        style="@style/Widget.WaterBuddy.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/drink_custom_button"
        android:textColor="@color/water_blue_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonRowCard" />

    <TextView
        android:id="@+id/tvGoalHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="@string/goal_reached_hint"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnCustomAmount"
        tools:visibility="visible" />

    <!-- 하단 네비게이션 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>

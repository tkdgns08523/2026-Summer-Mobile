<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_card"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/tvDialogEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="56sp"
        tools:text="🙆" />

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textSize="19sp"
        android:textStyle="bold"
        tools:text="목 좌우 늘리기" />

    <TextView
        android:id="@+id/tvDialogDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        tools:text="고개를 천천히 좌우로 기울여 목 옆쪽 근육을 늘려주세요." />

    <TextView
        android:id="@+id/tvDialogTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:textColor="@color/water_blue_dark"
        android:textSize="44sp"
        android:textStyle="bold"
        tools:text="20" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogStart"
        style="@style/Widget.WaterBuddy.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="52dp"
        android:layout_marginTop="20dp"
        android:text="@string/stretch_start_button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogCancel"
        style="@style/Widget.WaterBuddy.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginTop="4dp"
        android:text="@string/stretch_cancel_button" />

</LinearLayout>

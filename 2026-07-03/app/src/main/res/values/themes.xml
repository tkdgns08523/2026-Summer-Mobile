<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ProjectApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/water_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/water_blue</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/accent_mint_dark</item>
        <item name="colorSecondaryContainer">@color/water_bg</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceVariant">@color/water_bg</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/track_grey</item>
        <item name="android:statusBarColor">@color/water_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="materialButtonStyle">@style/Widget.WaterBuddy.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.WaterBuddy.BottomNavigationView</item>
        <item name="materialCardViewStyle">@style/Widget.WaterBuddy.Card</item>
        <item name="textInputStyle">@style/Widget.WaterBuddy.TextField</item>
        <item name="android:windowBackground">@color/water_bg</item>
    </style>

    <style name="Theme.ProjectApplication" parent="Base.Theme.ProjectApplication" />

    <!-- 둥글고 그림자가 있는 필 형태 버튼 -->
    <style name="Widget.WaterBuddy.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="elevation">3dp</item>
        <item name="backgroundTint">@color/water_blue_dark</item>
    </style>

    <!-- 보조(아웃라인) 버튼 -->
    <style name="Widget.WaterBuddy.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="strokeColor">@color/water_blue</item>
        <item name="strokeWidth">1.75dp</item>
        <item name="android:textColor">@color/water_blue_dark</item>
    </style>

    <!-- 텍스트 버튼(작은 액션) -->
    <style name="Widget.WaterBuddy.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- 카드 기본 스타일: 넓은 라운드 + 은은한 그림자 -->
    <style name="Widget.WaterBuddy.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">20dp</item>
    </style>

    <!-- 텍스트필드: 라운드 아웃라인 -->
    <style name="Widget.WaterBuddy.TextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/water_blue_dark</item>
        <item name="hintTextColor">@color/water_blue_dark</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundColor">@color/surface_card</item>
    </style>

    <!-- 하단 네비게이션: 살짝 뜬 느낌의 라운드 + 알약형 활성 표시 -->
    <style name="Widget.WaterBuddy.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="elevation">12dp</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.WaterBuddy.BottomNavigationView.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:background">@color/surface_card</item>
    </style>

    <style name="Widget.WaterBuddy.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/water_bg</item>
    </style>

    <!-- 타이포그래피 스케일 -->
    <style name="TextAppearance.WaterBuddy.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WaterBuddy.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WaterBuddy.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WaterBuddy.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- 다이얼로그 -->
    <style name="ThemeOverlay.WaterBuddy.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="dialogCornerRadius">28dp</item>
    </style>
</resources>
